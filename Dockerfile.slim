ARG CZKAWKA_VERSION=11.0.1
ARG CZKAWKA_SHA256_AMD64=2f81d63f79047294629253f4232c47cf5a2c6e55b9e34f23d11c2c810cfcbc09
ARG CZKAWKA_SHA256_ARM64=eb333e3b29d576db6d2365cd9deff454cfc9e7bc9b8b6dfefb4ab82b14db7dc8

ARG RGA_VERSION=0.10.10
ARG RGA_SHA256_AMD64=a969c25b182ac84aa672518313b5f741091decf7d93d03a020bcfe517b9ff4e8
ARG RGA_SHA256_ARM64=2cd875ab6c78b27e4830b5bca92c570a8a8dcfb368bc71b189b65ac01fbc3020

RUN set -e; \
    case "$TARGETARCH" in \
      amd64) czkawka_asset="linux_czkawka_cli_x86_64"; czkawka_sha256="$CZKAWKA_SHA256_AMD64" ;; \
      arm64) czkawka_asset="linux_czkawka_cli_arm64"; czkawka_sha256="$CZKAWKA_SHA256_ARM64" ;; \
      *) echo "Unsupported Czkawka architecture: $TARGETARCH" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/qarmin/czkawka/releases/download/${CZKAWKA_VERSION}/${czkawka_asset}" -o /tmp/czkawka_cli; \
    echo "${czkawka_sha256}  /tmp/czkawka_cli" | sha256sum -c -; \
    install -m 0755 /tmp/czkawka_cli /usr/local/bin/czkawka_cli; \
    ln -sf /usr/local/bin/czkawka_cli /usr/local/bin/czkawka; \
    rm -f /tmp/czkawka_cli; \
    case "$TARGETARCH" in \
      amd64) rga_target="x86_64-unknown-linux-musl"; rga_sha256="$RGA_SHA256_AMD64" ;; \
      arm64) rga_target="aarch64-unknown-linux-gnu"; rga_sha256="$RGA_SHA256_ARM64" ;; \
      *) echo "Unsupported ripgrep-all architecture: $TARGETARCH" >&2; exit 1 ;; \
    esac; \
    rga_dir="ripgrep_all-v${RGA_VERSION}-${rga_target}"; \
    curl -fsSL "https://github.com/phiresky/ripgrep-all/releases/download/v${RGA_VERSION}/${rga_dir}.tar.gz" -o /tmp/rga.tar.gz; \
    echo "${rga_sha256}  /tmp/rga.tar.gz" | sha256sum -c -; \
    tar -xzf /tmp/rga.tar.gz -C /tmp; \
    install -m 0755 "/tmp/${rga_dir}/rga" /usr/local/bin/rga; \
    install -m 0755 "/tmp/${rga_dir}/rga-preproc" /usr/local/bin/rga-preproc; \
    install -m 0755 "/tmp/${rga_dir}/rga-fzf" /usr/local/bin/rga-fzf; \
    install -m 0755 "/tmp/${rga_dir}/rga-fzf-open" /usr/local/bin/rga-fzf-open; \
    rm -rf /tmp/rga.tar.gz "/tmp/${rga_dir}"; \
    czkawka --version; \
    rga --version

